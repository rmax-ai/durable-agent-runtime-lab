# Durable Agent Runtime Lab — environment configuration
# Copy to .envrc or export these variables

# Model provider configuration
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1

# Runtime configuration
DAR_DATA_DIR=./data
DAR_SANDBOX_MODE=process
# DAR_SANDBOX_MODE=docker

# Logging
DAR_LOG_LEVEL=INFO
DAR_LOG_FORMAT=json
